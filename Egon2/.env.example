# Egon2 — Beispielkonfiguration
# Kopieren nach .env und Werte anpassen.
# NICHT in git committen.

# ── LLM ────────────────────────────────────────────────────────────────────
LLM_API_URL=http://<host>:<port>/v1/chat/completions
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60.0

# ── Matrix ──────────────────────────────────────────────────────────────────
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER_ID=@egon:example.org
MATRIX_DEVICE_NAME=Egon2-Bot
# Bevorzugter Login: Access-Token + Device-ID statt Passwort
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_ID=
# Alternativ: Passwort-Login (nur bei erstem Start / Token-Erzeugung)
MATRIX_PASSWORD=

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
# Kommagetrennte User-IDs, die Nachrichten senden dürfen
TELEGRAM_WHITELIST=[123456789]

# ── Externe Dienste ─────────────────────────────────────────────────────────
KNOWLEDGE_URL=http://<host>:8080
SEARXNG_URL=http://<host>:8080
BOOKSTACK_URL=https://bookstack.example.org
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=
BOOKSTACK_EGON_BOOK_ID=1

# ── News-Briefing ────────────────────────────────────────────────────────────
# Matrix-Room-ID (Format: !<id>:<server>)
NEWS_REPORT_MATRIX_ROOM=
# Telegram-Chat-ID (numerisch)
NEWS_REPORT_TELEGRAM_CHAT=

# ── Pfade ────────────────────────────────────────────────────────────────────
DATA_DIR=/opt/egon2/data
BACKUP_DIR=/opt/egon2/backup
SCHEDULER_DB_PATH=/opt/egon2/data/scheduler.db
SSH_KEY_PATH=/opt/egon2/.ssh/id_ed25519
SSH_KNOWN_HOSTS=

# ── Limits ───────────────────────────────────────────────────────────────────
DAILY_COST_EUR_SOFT_LIMIT=5.0
MESSAGE_QUEUE_MAXSIZE=100
CONSUMER_SEMAPHORE_SIZE=3
