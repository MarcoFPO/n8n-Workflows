        "id": "da3fb5cb-daa9-4b60-bbb9-8f015f413625"
      },
      {
        "parameters": {
          "jsCode": "const ticket = $input.first().json;\nconst cfg = $('📋 Set Check Config').first().json;\n\n// Pause-Bedingung aus Ticket-Notizen extrahieren\n// Die letzte Notiz des Execute-Phase enthält den pause_condition-Hinweis\nconst system_name = ticket.wer || 'unbekannt';\nconst system_ip = ticket.system_ip || null;\nconst problem = ticket.was || 'unbekannt';\nconst ticket_id = ticket.ticket_id;\n\n// SSH-Zugang für Health-Check aufbauen\n// Wir versuchen: ssh root@10.1.1.100 pct exec <lxc_id> -- hostname\n// ODER: ssh root@<system_ip> hostname\nconst ssh_check_cmd = system_ip\n  ? `ssh -o ConnectTimeout=5 -o BatchMode=yes root@${system_ip} 'echo ONLINE && hostname && uptime' 2>&1`\n  : `echo 'Kein SSH-Zugang bekannt – System-IP nicht gespeichert'`;\n\nconst prompt = `Du bist ein DevOps-Engineer der prüft ob ein pausiertes Incident-Ticket wieder aufgenommen werden kann.\n\nTicket-Informationen:\n- Ticket-ID: ${ticket_id}\n- Device/System: ${system_name}\n- Problem: ${problem}\n- System-IP: ${system_ip || 'unbekannt'}\n- Ticket erstellt: ${ticket.wan || 'unbekannt'}\n\nDeine Aufgabe:\n1. Prüfe ob das System \"${system_name}\" wieder erreichbar ist\n2. Führe dazu folgenden SSH-Health-Check aus:\n   ${ssh_check_cmd}\n3. Wenn das System erreichbar ist (SSH antwortet): Empfehle RESUME\n4. Wenn das System nicht erreichbar ist: Empfehle KEEP_PAUSED\n5. Wenn die System-IP unbekannt ist: Prüfe ob vergangene Zeit > 30min (Check-Zeit: ${cfg.check_time})\n\nAntworte NUR als JSON:\n{\n  \"decision\": \"RESUME\" oder \"KEEP_PAUSED\",\n  \"reason\": \"Kurze Begründung\",\n  \"system_online\": true/false/null,\n  \"confidence\": 0-100\n}`;\n\nreturn [{ json: { ticket_id, ticket, system_name, system_ip, problem, prompt } }];"
        },
        "name": "🔧 Build Check Prompt",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1840,
          300
        ],
        "id": "86ba0e68-37f5-4e9a-bf71-46d15fc5ca51"
      },
      {
