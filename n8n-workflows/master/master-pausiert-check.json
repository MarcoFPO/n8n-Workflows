      },
      {
        "parameters": {
          "jsCode": "// Ticket wird fortgesetzt → Status zurück auf 'in Arbeit' setzen\nconst input = $input.first().json;\n\nconst note_body = `## ▶️ Bearbeitung fortgesetzt\\n\\n**Pausiert-Check:** Bedingung erfüllt – System wieder verfügbar.\\n\\n**System:** ${input.system_name} (${input.system_ip || 'IP unbekannt'})\\n**Claude-Bewertung:** ${input.reason}\\n**Konfidenz:** ${input.confidence}%\\n\\nDer Incident-Response-Workflow wird automatisch neu gestartet.`;\n\nreturn [{ json: {\n  ticket_id: input.ticket_id,\n  note_title: '▶️ Bearbeitung fortgesetzt – Bedingung erfüllt',\n  note_body,\n  new_state: 'in Arbeit',\n  // Für Re-Trigger\n  system_name: input.system_name,\n  reason: input.reason\n} }];"
        },
