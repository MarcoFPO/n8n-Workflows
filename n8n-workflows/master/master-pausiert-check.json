      },
      {
        "parameters": {
          "jsCode": "// Alle Tickets verarbeitet – Zusammenfassung\nconst items = $input.all();\nconst resumed = items.filter(i => i.json.action === 'resumed').length;\nconst kept_paused = items.filter(i => i.json.action === 'keep_paused').length;\n\nreturn [{ json: {\n  status: 'check_complete',\n  total_checked: items.length,\n  resumed,\n  kept_paused,\n  timestamp: new Date().toISOString()\n} }];"
