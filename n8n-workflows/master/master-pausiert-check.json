    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst ticket_ids = result.ticket_ids || [];\n\nif (ticket_ids.length === 0) {\n  return [{ json: { has_tickets: false, count: 0, ticket_ids: [] } }];\n}\n\nreturn [{ json: { has_tickets: true, count: ticket_ids.length, ticket_ids } }];"
      },
