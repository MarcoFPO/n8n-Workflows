          "jsCode": "const input = $('🔧 Build Resume Note').first().json;\nconst trigger_result = $input.first().json;\nconst success = !trigger_result.error && trigger_result.status !== 'error';\n\nreturn [{ json: {\n  ticket_id: input.ticket_id,\n  action: 'resumed',\n  system_name: input.system_name,\n  webhook_triggered: success,\n  timestamp: new Date().toISOString()\n} }];"
