    {
      "parameters": {
        "jsCode": "// Ticket-IDs in Einzel-Items aufteilen für Loop\nconst { ticket_ids } = $input.first().json;\nreturn ticket_ids.map(id => ({ json: { ticket_id: id } }));"
      },
      "name": "🔧 Split Ticket IDs",
      "type": "n8n-nodes-base.code",
