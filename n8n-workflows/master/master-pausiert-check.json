    {
      "parameters": {
        "jsCode": "// Kein pausiertes Ticket – reguläres Ende\nconst cfg = $('📋 Set Check Config').first().json;\nreturn [{ json: {\n  status: 'no_paused_tickets',\n  checked_at: cfg.check_time,\n  message: 'Keine Tickets im Status \"pausiert\" gefunden.'\n} }];"
      },
