        "parameters": {
          "jsCode": "// Ticket bleibt pausiert – kein Eingriff nötig\nconst input = $input.first().json;\nreturn [{ json: {\n  ticket_id: input.ticket_id,\n  action: 'keep_paused',\n  reason: input.reason,\n  confidence: input.confidence,\n  timestamp: new Date().toISOString()\n} }];"
        },
