      "name": "🏥 SUB: Health Check",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [
        1400,
        300
      ],
      "notes": "Prüft Disk/Memory/CPU/Services. Output: health_status (ok/warning/critical), Metriken."
    },
    {
      "parameters": {
        "jsCode": "// Collect issues from log analysis and health check, combine with system info\nconst allItems = $input.all();\nconst healthData = allItems[0]?.json || {};\n\n// Try to get log analysis result (from previous nodes in the loop)\nlet logData = {};\ntry {\n  // Try to access log analyser result - may come from any of the 3 routes\n  const logItems = [\n    ...(($('📋 SUB: Log Analyser (VM)').all && $('📋 SUB: Log Analyser (VM)').all()) || []),\n    ...(($('📋 SUB: Log Analyser (LXC)').all && $('📋 SUB: Log Analyser (LXC)').all()) || []),\n    ...(($('📋 SUB: Log Analyser (Device)').all && $('📋 SUB: Log Analyser (Device)').all()) || [])\n  ];\n  if (logItems.length > 0) logData = logItems[logItems.length - 1].json;\n} catch (e) {}\n\nconst issues = logData.issues || [];\nconst criticalIssues = issues.filter(i => i.severity === 'critical');\nconst hasCritical = criticalIssues.length > 0 || healthData.health_status === 'critical';\n\nreturn [{\n  json: {\n    name: healthData.name || logData.name || 'Unknown',\n    type: healthData.type || logData.type || 'unknown',\n    ip: healthData.ip || logData.ip || 'N/A',\n    health_status: healthData.health_status || 'unknown',\n    disk_usage_pct: healthData.disk_usage_pct || 0,\n    memory_usage_pct: healthData.memory_usage_pct || 0,\n    cpu_load: healthData.cpu_load || 0,\n    services_ok: healthData.services_ok !== undefined ? healthData.services_ok : true,\n    log_issues: issues,\n    has_issues: logData.has_issues || false,\n    has_critical: hasCritical,\n    critical_issues: criticalIssues\n  }\n}];"
      },
      "name": "🔧 Collect Issues",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        300
      ],
      "notes": "Kombiniert Health-Check und Log-Analyse Ergebnisse pro System"
    },
