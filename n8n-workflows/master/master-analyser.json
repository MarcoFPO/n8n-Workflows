    {
      "parameters": {
        "jsCode": "// Aggregate all system results for the daily report\nconst allItems = $input.all();\nconst systems = allItems.map(i => i.json).filter(s => s && s.name);\n\nconst summary = {\n  run_id: $('📋 Set Analyse Config').first().json.run_id || 'unknown',\n  date: new Date().toISOString().slice(0, 10),\n  total_systems: systems.length,\n  critical: systems.filter(s => s.health_status === 'critical' || s.has_critical).length,\n  warning: systems.filter(s => s.health_status === 'warning' && !s.has_critical).length,\n  ok: systems.filter(s => s.health_status === 'ok' && !s.has_critical).length,\n  with_issues: systems.filter(s => s.has_issues).length\n};\n\nreturn [{\n  json: {\n    summary,\n    systems,\n    report_data: JSON.stringify(systems)\n  }\n}];"
      },
      "name": "🔧 Aggregate Daily Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
