    {
      "id": "find-book-01",
      "name": "🔍 BookStack: Suche Buch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://bookstack.doehlercomputing.de/api/books",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token a5FgBtyb3qJCZZRM2zgpvMn0eIMVIkcJ:fRt0WwEHGwRvZh5YzC8djKZ6rM0rJrin"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filter[name]",
              "value": "Störungsbearbeitung"
            },
            {
              "name": "count",
              "value": "5"
            }
          ]
        },
        "options": {
          "timeout": 10000,
          "continueOnFail": true
        }
      }
    },
    {
      "id": "check-book-01",
      "name": "🔧 Check Book",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        300
      ],
      "parameters": {
        "jsCode": "// Prüfe ob Buch 'Störungsbearbeitung' existiert\nconst bookResult = $input.first().json;\nconst input = $('📥 Input from Master').first().json;\n\nlet book_id = null;\n\nif (bookResult.data && bookResult.data.length > 0) {\n  // Exakter Name-Match\n  const exact = bookResult.data.find(b => b.name === 'Störungsbearbeitung');\n  book_id = exact ? exact.id : null;  // kein Fallback auf falsches Buch\n}\n\n// Tags parsen\nlet tags = [];\ntry {\n  tags = typeof input.tags === 'string' ? JSON.parse(input.tags) : (input.tags || []);\n} catch(e) {\n  tags = ['incident'];\n}\n\nreturn [{\n  json: {\n    book_id,\n    book_exists: book_id !== null,\n    title: input.title,\n    content_markdown: input.content_markdown,\n    component: input.component || 'Allgemein',\n    affected_system: input.affected_system || 'Unbekannt',\n    tags\n  }\n}];"
      }
    },
    {
      "id": "if-book-01",
      "name": "✅ IF: Buch existiert?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        800,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "book-exists",
              "leftValue": "={{ $json.book_exists }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "false"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "create-book-01",
      "name": "📚 BookStack: Create Buch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "https://bookstack.doehlercomputing.de/api/books",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token a5FgBtyb3qJCZZRM2zgpvMn0eIMVIkcJ:fRt0WwEHGwRvZh5YzC8djKZ6rM0rJrin"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"name\": \"Störungsbearbeitung\", \"description\": \"Dokumentation von Störungen, Fehlern und deren Lösungen – automatisch befüllt durch n8n Incident Response\"}",
        "options": {
          "timeout": 10000,
          "continueOnFail": true
        }
      }
    },
    {
      "id": "resolve-book-01",
      "name": "🔧 Resolve Book ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "jsCode": "// Ermittle finale Book ID\nconst checkData = $('🔧 Check Book').first().json;\nlet book_id = checkData.book_id;\n\n// Falls Buch gerade erstellt wurde\ntry {\n  const created = $('📚 BookStack: Create Buch').first().json;\n  if (created && created.id) {\n    book_id = created.id;\n  }\n} catch(e) {\n  // Create-Node hat nicht gelaufen (Buch existierte bereits)\n}\n\nreturn [{\n  json: {\n    ...checkData,\n    book_id\n  }\n}];"
      }
    },
    {
      "id": "find-chapter-01",
      "name": "🔍 BookStack: Suche Kapitel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1400,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "https://bookstack.doehlercomputing.de/api/chapters",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token a5FgBtyb3qJCZZRM2zgpvMn0eIMVIkcJ:fRt0WwEHGwRvZh5YzC8djKZ6rM0rJrin"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filter[book_id]",
              "value": "={{ $json.book_id }}"
            },
            {
              "name": "filter[name]",
              "value": "={{ $json.component }}"
            }
          ]
        },
        "options": {
          "timeout": 10000,
          "continueOnFail": true
        }
      }
    },
    {
      "id": "check-chapter-01",
      "name": "🔧 Check Chapter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        300
      ],
      "parameters": {
        "jsCode": "// Prüfe ob Kapitel existiert\nconst chapterResult = $input.first().json;\nconst bookData = $('🔧 Resolve Book ID').first().json;\n\nlet chapter_id = null;\n\nif (chapterResult.data && chapterResult.data.length > 0) {\n  chapter_id = chapterResult.data[0].id;\n}\n\nreturn [{\n  json: {\n    ...bookData,\n    chapter_id,\n    chapter_exists: chapter_id !== null\n  }\n}];"
      }
    },
    {
      "id": "if-chapter-01",
      "name": "✅ IF: Kapitel existiert?",
      "type": "n8n-nodes-base.if",
