      "name": "📂 BookStack: Create Kapitel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "https://bookstack.doehlercomputing.de/api/chapters",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token a5FgBtyb3qJCZZRM2zgpvMn0eIMVIkcJ:fRt0WwEHGwRvZh5YzC8djKZ6rM0rJrin"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ book_id: $('🔧 Check Chapter').first().json.book_id, name: $('🔧 Check Chapter').first().json.component, description: 'Störungen und Lösungen für ' + $('🔧 Check Chapter').first().json.component }) }}",
        "options": {
          "timeout": 10000,
          "continueOnFail": true
        }
      }
    },
    {
      "id": "resolve-chapter-01",
      "name": "🔧 Resolve Chapter ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        300
      ],
      "parameters": {
        "jsCode": "// Ermittle finale Chapter ID\nconst checkData = $('🔧 Check Chapter').first().json;\nlet chapter_id = checkData.chapter_id;\n\ntry {\n  const created = $('📂 BookStack: Create Kapitel').first().json;\n  if (created && created.id) {\n    chapter_id = created.id;\n  }\n} catch(e) {\n  // Create-Node hat nicht gelaufen\n}\n\nreturn [{\n  json: {\n    ...checkData,\n    chapter_id\n  }\n}];"
      }
    },
    {
      "id": "create-page-01",
      "name": "📄 BookStack: Create Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2400,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://bookstack.doehlercomputing.de/api/pages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token a5FgBtyb3qJCZZRM2zgpvMn0eIMVIkcJ:fRt0WwEHGwRvZh5YzC8djKZ6rM0rJrin"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ book_id: $json.book_id, chapter_id: $json.chapter_id, name: $json.title, markdown: $json.content_markdown, tags: ($json.tags || []).map(t => ({ name: t })) }) }}",
        "options": {
          "timeout": 15000,
          "continueOnFail": true
        }
      }
    },
    {
      "id": "process-result-01",
      "name": "🔧 Process Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2600,
        300
      ],
      "parameters": {
        "jsCode": "// Ergebnis aufbereiten\nconst pageResult = $input.first().json;\nconst chapterData = $('🔧 Resolve Chapter ID').first().json;\n\nconst success = !pageResult.error && pageResult.id != null;\nconst page_url = pageResult.url || `https://bookstack.doehlercomputing.de/books/${chapterData.book_id}/page/${pageResult.id || 'unknown'}`;\n\nreturn [{\n  json: {\n    success,\n    page_id: pageResult.id || null,\n    page_url,\n    title: chapterData.title,\n    book_id: chapterData.book_id,\n    chapter_id: chapterData.chapter_id,\n    error: pageResult.error || null\n  }\n}];"
      }
    }
