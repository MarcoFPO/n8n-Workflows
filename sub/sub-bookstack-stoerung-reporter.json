            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "chapter-exists",
              "leftValue": "={{ $json.chapter_exists }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "false"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
