# Zabbix osTicket Webhook Service Configuration

# osTicket API Configuration
OSTICKET_URL=http://osticket.local/api
OSTICKET_API_KEY=your_api_key_here

# Webhook Security (optional, for HMAC signature verification)
ZABBIX_WEBHOOK_SECRET=your_secret_key

# Logging
LOG_FILE=/var/log/zabbix_osticket_webhook.log

# Server Configuration
HOST=0.0.0.0
PORT=8000
