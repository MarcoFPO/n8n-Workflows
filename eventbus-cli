#!/bin/bash
#
# Redis Event-Bus CLI Tool - Einfacher Wrapper für aktienanalyse-ökosystem
# Vereinfachter Zugang zum Event-Bus Testing und Monitoring
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/cli_event_bus_tester.py"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color

# Banner function
show_banner() {
    echo -e "${BLUE}"
    echo "================================================================"
    echo "🚌 Redis Event-Bus CLI Tool für aktienanalyse-ökosystem"
    echo "================================================================"
    echo -e "${NC}"
    echo -e "${CYAN}System: ${WHITE}Production-Ready Redis Event-Bus Infrastructure${NC}"
    echo -e "${CYAN}Services: ${WHITE}6 Microservices (Account, Order, Intelligence, Data, Market, Frontend)${NC}"
    echo -e "${CYAN}Features: ${WHITE}Performance Testing, Live-Monitoring, System Reports${NC}"
    echo ""
}

# Help function
show_help() {
    show_banner
    echo -e "${WHITE}Verfügbare Befehle:${NC}"
    echo ""
    echo -e "${GREEN}🏥 health${NC}              - Quick System Health Check"
    echo -e "${GREEN}⚡ test [basic|full]${NC}   - Performance Tests (basic=schnell, full=umfassend)"
    echo -e "${GREEN}📊 monitor [minutes]${NC}   - Live-Monitoring (default: 60 Minuten)"
    echo -e "${GREEN}📋 report [hours]${NC}      - System Report generieren (default: 24 Stunden)"
    echo -e "${GREEN}📈 status${NC}              - Aktueller System Status"
    echo ""
    echo -e "${WHITE}Beispiele:${NC}"
    echo -e "${YELLOW}  eventbus-cli health${NC}           # Schneller Gesundheitscheck"
    echo -e "${YELLOW}  eventbus-cli test${NC}             # Basic Performance Test"
    echo -e "${YELLOW}  eventbus-cli test full${NC}        # Umfassende Performance Tests"
    echo -e "${YELLOW}  eventbus-cli monitor 30${NC}       # 30 Minuten Live-Monitoring"
    echo -e "${YELLOW}  eventbus-cli report 48${NC}        # 48-Stunden System Report"
    echo -e "${YELLOW}  eventbus-cli status${NC}           # System Status anzeigen"
    echo ""
    echo -e "${PURPLE}💡 Tipp: Verwende 'health' für schnelle Überprüfung vor wichtigen Trading-Operationen${NC}"
    echo ""
}

# Check if Python script exists
if [ ! -f "$PYTHON_SCRIPT" ]; then
    echo -e "${RED}❌ Fehler: Python Script nicht gefunden: $PYTHON_SCRIPT${NC}"
    exit 1
fi

# Check if Python 3 is available
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}❌ Fehler: Python 3 ist nicht installiert${NC}"
    exit 1
fi

# Main command handling
case "$1" in
    "health")
        show_banner
        echo -e "${CYAN}🏥 Führe System Health Check durch...${NC}"
        python3 "$PYTHON_SCRIPT" health
        ;;
    
    "test")
        show_banner
        if [ "$2" = "full" ] || [ "$2" = "comprehensive" ]; then
            echo -e "${CYAN}🚀 Starte umfassende Performance Tests...${NC}"
            echo -e "${YELLOW}⚠️ Warnung: Dies kann 10-15 Minuten dauern!${NC}"
            python3 "$PYTHON_SCRIPT" test comprehensive
        else
            echo -e "${CYAN}⚡ Starte Basic Performance Test...${NC}"
            python3 "$PYTHON_SCRIPT" test basic
        fi
        ;;
    
    "monitor")
        DURATION=${2:-60}
        show_banner
        echo -e "${CYAN}📊 Starte Live-Monitoring für $DURATION Minuten...${NC}"
        echo -e "${YELLOW}💡 Tipp: Drücke Ctrl+C zum vorzeitigen Stoppen${NC}"
        python3 "$PYTHON_SCRIPT" monitor --duration "$DURATION"
        ;;
    
    "report")
        HOURS=${2:-24}
        show_banner
        echo -e "${CYAN}📋 Generiere System Report für die letzten $HOURS Stunden...${NC}"
        python3 "$PYTHON_SCRIPT" report --hours "$HOURS"
        ;;
    
    "status")
        show_banner
        echo -e "${CYAN}📈 System Status wird abgerufen...${NC}"
        python3 "$PYTHON_SCRIPT" status
        ;;
    
    "help"|"-h"|"--help"|"")
        show_help
        ;;
    
    *)
        echo -e "${RED}❌ Unbekannter Befehl: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac